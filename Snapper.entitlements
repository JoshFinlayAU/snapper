<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Snapper is a LAN management tool that talks to BMC/Redfish endpoints and stores
         server credentials in the login Keychain, so it runs unsandboxed. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <!-- Outbound HTTPS to BMC management interfaces. -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
